# ============================================
# SERVER
# ============================================
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://clinical_user:clinical_pass@postgres:5432/clinical_db"

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=redis_pass

# ============================================
# JWT
# ============================================
JWT_ACCESS_SECRET=your_super_secret_access_key_change_this_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CLOUDINARY
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# ML SERVICE
# In Docker: use service name. Locally: use localhost
# ============================================
ML_SERVICE_URL=http://ml-service:8000

# ============================================
# POSTGRES (for docker-compose)
# ============================================
POSTGRES_USER=clinical_user
POSTGRES_PASSWORD=clinical_pass
POSTGRES_DB=clinical_db