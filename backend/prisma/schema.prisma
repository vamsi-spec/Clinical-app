generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



//Enums

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
}

enum AppointmentType {
  SCHEDULED
  WALK_IN
  FOLLOW_UP
  REFERRAL
  EMERGENCY
}

enum Severity{
    LOW
    MEDIUM
    HIGH
    CRITICAL
}

enum AppointmentStatus{
    SCHEDULED
    COMPLETED
    CANCELLED
    NO_SHOW
}

enum PipelineStatus {
    PENDING
    TRANSCRIBING
    CORRECTING
    DIARIZING
    EXTRACTING_ENTITIES
    GENERATING_SOAP
    GENERATING_BILLING
    COMPLETED
    FAILED
}

model User {
    id              String @id @default(uuid())
    email           String @unique
    passwordHash    String
    firstName       String
    lastName        String
    role            Role
    speciality      String? //only for doctors
    assignedDoctorId String? //only for nurse role
    isActive        Boolean @default(true) 
    lastLoginAt     DateTime?
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt


    assignedDoctor User?     @relation("NurseDoctor", fields: [assignedDoctorId], references: [id])
    nurses         User[]    @relation("NurseDoctor")

    patients Patient[] 
    visits   Visit[]
    appointments Appointment[]
    auditLogs  AuditLog[]


    @@index([role])
    @@index([email])

}


//Patient

model Patient {
  id            String @id @default(uuid())
  mrn           String @unique
  doctorId      String
  name          String
  dob           DateTime
  gender        String
  bloodType     String?
  allergies     String[]
  currentMedications   String[]
  phone         String?
  email         String?
  address       String? @db.Text
  city          String?
  state         String?
  pincode       String?


  emergencyContact String?
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRel   String?

  primaryInsurance   String?
  insuranceNumber    String?
  secondaryInsurance String?

  pastSurgeries      String[]
  chronicConditions  String[]
  familyHistory      String?   @db.Text

  consentGiven       Boolean   @default(false)
  consentDate        DateTime?

  referredBy         String?   // doctorId who referred

  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deletedAt          DateTime?
  deletedBy          String?


  doctor        User       @relation(fields: [doctorId], references:[id])
  visits        Visit       []
  appointments    Appointment[]
  trends          PatientTrend[]

  @@index([doctorId])
  @@index([name])
}

//Visit

model Visit {
  id     String @id @default(uuid())
  patientId String
  doctorId   String
  audioFileUrl    String?
  audoPublicId    String?
  duration    Int?
  visitDate   DateTime  @default(now())
  pipelineStatus  PipelineStatus  @default(PENDING)
  pipelineError   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient       Patient   @relation(fields: [patientId], references: [id])
  doctor        User      @relation(fields: [doctorId], references: [id])

  soapNote      SOAPNote?
  nerResult     NERResult?
  drugInteractions    DrugInteraction[]
  billingCode         BillingCode?

  @@index([patientId])
  @@index([doctorId])
  @@index([visitDate])
  @@index([patientId, doctorId, visitDate])
}


//soapNote

model SOAPNote {
  id        String  @id @default(uuid())
  visitId   String  @unique
  subjective    String    @db.Text
  objective     String?   @db.Text
  assessment    String?   @db.Text
  plan          String?   @db.Text
  explainableNote   Json  @default("{}")
  auditHash     String?   //SHA-256 for finalized one
  versions      Json      @default("[]")
  isFinalized   Boolean   @default(false)
  finalizedAt   DateTime?
  finalizedBy   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt


  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  @@index([visitId])

}


model NERResult {
  id          String  @id @default(uuid())
  visitId     String  @unique
  medications Json    @default("[]")
  symptoms    Json    @default("[]")
  diagnoses   Json    @default("[]")
  rawSegments Json    @default("[]")
  createdAt   DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}


model DrugInteraction {
  id        String      @id @default(uuid())
  visitId   String      
  drug1     String
  drug2     String
  severity  Severity
  description String  @db.Text
  source    String    @default("rxnav")
  createdAt DateTime  @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}


model BillingCode {
  id          String    @id @default(uuid())
  visitId     String    @unique
  icd10Codes  Json      @default("[]")
  cptCode     Json      @default("{}")
  codingGaps  Json      @default("[]")
  confirmedCodes   Json      @default("[]")
  isConfirmed   Boolean   @default(false)
  confirmedAt DateTime?
  confirmedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model AuditLog {
  id                  String     @id   @default(uuid())
  userId              String?
  action              String
  resourceType        String     //visit,patient,User which record affected
  resourceId          String?
  ipAddress           String
  userAgent           String?
  metadata            Json?
  createdAt           DateTime   @default(now())
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([resourceType])
}



model Appointment {
  id            String    @id @default(uuid())
  patientId     String
  doctorId      String
  scheduledAt DateTime
  duration      Int @default(30)
  status        AppointmentStatus   @default(SCHEDULED)
  notes         String?
  type          AppointmentType  @default(SCHEDULED)
  chiefComplaint     String?   // why is patient coming
  cancelReason       String?
  cancelledBy        String? 
  reminderSent       Boolean   @default(false)
  isWalkIn           Boolean   @default(false)
  followUpOf         String?   // appointmentId — if this is a follow-up visit
  bufferMinutes      Int       @default(10)


  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  patient Patient @relation(fields: [patientId], references: [id])
  doctor User   @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledAt])
  @@index([doctorId, scheduledAt])
}


model PatientTrend {
  id          String  @id @default(uuid())
  patientId   String
  metricType  String
  value       Float
  unit        String
  recordedAt  DateTime
  visitId     String?

  notes       String?
  createdAt   DateTime   @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([patientId, metricType])
  @@index([patientId, metricType, recordedAt])
}