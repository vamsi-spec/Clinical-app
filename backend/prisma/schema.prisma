generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



//Enums

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
}

enum AppointmentType {
  SCHEDULED
  WALK_IN
  FOLLOW_UP
  REFERRAL
  EMERGENCY
}

enum TransferRequestStatus {
  PENDING    // doctor raised request — waiting for admin
  APPROVED   // admin approved — waiting for receptionist to execute
  REJECTED   // admin rejected — doctor notified
  COMPLETED  // receptionist executed — patient moved
  CANCELLED  // doctor cancelled their own request
}

enum Severity{
    LOW
    MEDIUM
    HIGH
    CRITICAL
}

enum AppointmentStatus{
    SCHEDULED
    COMPLETED
    CANCELLED
    NO_SHOW
}

enum PipelineStatus {
    PENDING
    TRANSCRIBING
    CORRECTING
    DIARIZING
    EXTRACTING_ENTITIES
    GENERATING_SOAP
    GENERATING_BILLING
    COMPLETED
    FAILED
}

model User {
    id              String @id @default(uuid())
    email           String @unique
    passwordHash    String
    firstName       String
    lastName        String
    role            Role
    speciality      String? //only for doctors
    assignedDoctorId String? //only for nurse role
    isActive        Boolean @default(true) 
    lastLoginAt     DateTime?
    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt


    assignedDoctor User?     @relation("NurseDoctor", fields: [assignedDoctorId], references: [id])
    nurses         User[]    @relation("NurseDoctor")
    transferRequestsRaised    TransferRequest[] @relation("TransferFrom")
    transferRequestsReceiving TransferRequest[] @relation("TransferTo")

    patients Patient[] @relation("PatientDoctor") 
    visits   Visit[]
    appointments Appointment[]
    auditLogs  AuditLog[]


    @@index([role])
    @@index([email])

}


//Patient

model Patient {
  id                    String    @id @default(uuid())
  mrn                   String    @unique

  // doctorId = the primary treating doctor
  // Set when receptionist registers patient and assigns to doctor
  doctorId              String

  // RECEPTIONIST-OWNED FIELDS
  // Only receptionist and admin can update these
  firstName             String
  lastName              String
  dob                   DateTime
  gender                String
  nationality           String?
  preferredLanguage     String?   @default("English")

  // Contact
  phone                 String?
  email                 String?
  address               String?   @db.Text
  city                  String?
  state                 String?
  pincode               String?

  // Emergency contact
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactRel   String?

  // Insurance
  primaryInsurance      String?
  insuranceNumber       String?
  secondaryInsurance    String?

  // Consent — receptionist records this at registration
  consentGiven          Boolean   @default(false)
  consentDate           DateTime?

  // DOCTOR-OWNED FIELDS
  // Only doctor and admin can update these
  bloodType             String?
  allergies             String[]
  currentMedications    String[]
  pastSurgeries         String[]
  chronicConditions     String[]
  familyHistory         String?   @db.Text

  // Referral — doctor sets this
  referredBy            String?   // doctorId who referred

  // ADMIN-ONLY FIELDS
  isActive              Boolean   @default(true)
  deletedAt             DateTime?
  deletedBy             String?
  deleteReason          String?

  // Registration metadata
  registeredBy          String?   // receptionistId who registered

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  doctor                User             @relation("PatientDoctor", fields: [doctorId], references: [id])
  visits                Visit[]
  appointments          Appointment[]
  trends                PatientTrend[]
  transferRequests      TransferRequest[]

  @@index([doctorId])
  @@index([mrn])
  @@index([firstName, lastName])
  @@index([isActive])
  @@index([doctorId, isActive])
}

// TRANSFER REQUEST
// Doctor raises → Admin approves → Receptionist executes
model TransferRequest {
  id            String                @id @default(uuid())
  patientId     String
  fromDoctorId  String
  toDoctorId    String
  requestedBy   String                // doctorId who raised request
  reason        String                @db.Text
  status        TransferRequestStatus @default(PENDING)

  // Admin review
  adminNote     String?               @db.Text
  reviewedBy    String?               // adminId
  reviewedAt    DateTime?

  // Receptionist execution
  executedBy    String?               // receptionistId
  executedAt    DateTime?

  // Doctor cancellation
  cancelledBy   String?
  cancelledAt   DateTime?
  cancelNote    String?

  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  // Relations
  patient       Patient               @relation(fields: [patientId], references: [id])
  fromDoctor    User                  @relation("TransferFrom", fields: [fromDoctorId], references: [id])
  toDoctor      User                  @relation("TransferTo", fields: [toDoctorId], references: [id])

  @@index([patientId])
  @@index([status])
  @@index([fromDoctorId])
  @@index([toDoctorId])
  @@index([requestedBy])
}
//Visit

model Visit {
  id     String @id @default(uuid())
  patientId String
  doctorId   String
  audioFileUrl    String?
  audoPublicId    String?
  duration    Int?
  visitDate   DateTime  @default(now())
  pipelineStatus  PipelineStatus  @default(PENDING)
  pipelineError   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  patient       Patient   @relation(fields: [patientId], references: [id])
  doctor        User      @relation(fields: [doctorId], references: [id])

  soapNote      SOAPNote?
  nerResult     NERResult?
  drugInteractions    DrugInteraction[]
  billingCode         BillingCode?

  @@index([patientId])
  @@index([doctorId])
  @@index([visitDate])
  @@index([patientId, doctorId, visitDate])
}


//soapNote

model SOAPNote {
  id        String  @id @default(uuid())
  visitId   String  @unique
  subjective    String    @db.Text
  objective     String?   @db.Text
  assessment    String?   @db.Text
  plan          String?   @db.Text
  explainableNote   Json  @default("{}")
  auditHash     String?   //SHA-256 for finalized one
  versions      Json      @default("[]")
  isFinalized   Boolean   @default(false)
  finalizedAt   DateTime?
  finalizedBy   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt


  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  @@index([visitId])

}


model NERResult {
  id          String  @id @default(uuid())
  visitId     String  @unique
  medications Json    @default("[]")
  symptoms    Json    @default("[]")
  diagnoses   Json    @default("[]")
  rawSegments Json    @default("[]")
  createdAt   DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}


model DrugInteraction {
  id        String      @id @default(uuid())
  visitId   String      
  drug1     String
  drug2     String
  severity  Severity
  description String  @db.Text
  source    String    @default("rxnav")
  createdAt DateTime  @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}


model BillingCode {
  id          String    @id @default(uuid())
  visitId     String    @unique
  icd10Codes  Json      @default("[]")
  cptCode     Json      @default("{}")
  codingGaps  Json      @default("[]")
  confirmedCodes   Json      @default("[]")
  isConfirmed   Boolean   @default(false)
  confirmedAt DateTime?
  confirmedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
}

model AuditLog {
  id                  String     @id   @default(uuid())
  userId              String?
  action              String
  resourceType        String     //visit,patient,User which record affected
  resourceId          String?
  ipAddress           String
  userAgent           String?
  metadata            Json?
  createdAt           DateTime   @default(now())
  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@index([resourceType])
}



model Appointment {
  id              String            @id @default(uuid())
  patientId       String
  doctorId        String
  scheduledAt     DateTime
  endsAt          DateTime
  duration        Int               @default(30)
  bufferMinutes   Int               @default(10)
  status          AppointmentStatus @default(SCHEDULED)
  type            AppointmentType   @default(SCHEDULED)

  // Set by receptionist at booking
  chiefComplaint  String?
  notes           String?           @db.Text
  isWalkIn        Boolean           @default(false)

  // Follow-up tracking
  followUpOf      String?

  // Cancellation — receptionist or doctor can cancel
  cancelReason    String?
  cancelledBy     String?
  cancelledAt     DateTime?

  // No-show — receptionist marks this
  noShowAt        DateTime?

  // Completion — doctor marks this
  completedAt     DateTime?
  completedBy     String?

  // Reminder
  reminderSent    Boolean           @default(false)
  reminderSentAt  DateTime?

  // Who booked — receptionist or doctor
  bookedBy        String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  patient         Patient           @relation(fields: [patientId], references: [id])
  doctor          User              @relation(fields: [doctorId], references: [id])

  @@index([doctorId])
  @@index([patientId])
  @@index([scheduledAt])
  @@index([doctorId, scheduledAt])
  @@index([status])
  @@index([doctorId, status, scheduledAt])
}


model PatientTrend {
  id          String  @id @default(uuid())
  patientId   String
  metricType  String
  value       Float
  unit        String
  recordedAt  DateTime
  visitId     String?

  notes       String?
  createdAt   DateTime   @default(now())

  patient Patient @relation(fields: [patientId], references: [id])

  @@index([patientId])
  @@index([patientId, metricType])
  @@index([patientId, metricType, recordedAt])
}